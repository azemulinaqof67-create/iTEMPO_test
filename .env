# ============================================
# МОДЕЛИ (опционально, по умолчанию из models_config.yaml)
# ============================================
# Текстовая модель для генерации ответов
# Основная модель - стабильный Flash Lite 2.5 (быстрый, доступен на free tier)
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Fallback цепочка при перегрузке/недоступности основной (через запятую, порядок важен):
# Tier-1 fallback: gemini-2.5-flash (переключаемся первой)
# Tier-2 fallback: gemma-3-27b-it (только если Tier-1 тоже недоступна)
#GEMINI_TEXT_MODEL_FALLBACK=gemini-2.5-flash,gemma-3-27b-it,gemma-3-4b-it,gemini-3.1-flash-lite-preview,gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-3-flash-preview
GEMINI_TEXT_MODEL_FALLBACK=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.5-flash,gemma-4-26b-a4b-it
# Голосовая модель для Live API
GEMINI_AUDIO_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Embedding модель
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
#GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview,gemini-embedding-001
VECTOR_SIZE=3072

CONTEXTUAL_TEXT_MODEL=gemini-flash-latest

# ============================================
# API ВЕРСИИ (опционально)
# ============================================
# Embedding API версия (v1beta для большинства моделей)
EMBEDDING_API_VERSION=v1beta
# Text API версия (пусто = авто-определение по модели)
# TEXT_API_VERSION=v1beta
# Live API версия для WebSocket соединений (v1alpha для Affective Dialog)
LIVE_API_VERSION=v1alpha

# ============================================
# RAG ПАРАМЕТРЫ (опционально)
# ============================================
# Размерность векторов (768 для 001, 3072 для v2-preview)
#VECTOR_SIZE=3072
# Размер чанков документов (в символах)
CHUNK_SIZE=1000
# Перекрытие между чанками (в символах)
CHUNK_OVERLAP=200
# Хранилище
STORAGE_PATH=qdrant_storage_v2
# Название коллекции в Qdrant
COLLECTION_NAME=documents_v2
# Лимит результатов поиска (передается в LLM)
SEARCH_LIMIT=20
# Лимит кандидатов для hybrid search (до re-ranking)
FETCH_LIMIT=40

# ============================================
# РАСШИРЕННЫЙ RAG PIPELINE (опционально)
# ============================================
# Contextual Retrieval - добавление контекста к чанкам через LLM (затратно!)
USE_CONTEXTUAL_RETRIEVAL=0
# Hybrid Search - Vector + BM25 + RRF
USE_HYBRID_SEARCH=1
# RAG Fusion - multi-query поиск (затратно!)
USE_RAG_FUSION=0
# LLM Reranking - переранжирование через LLM (затратно!)
USE_LLM_RERANK=0
# CRAG - самокоррекция качества поиска (затратно!)
USE_CRAG=0
# Semantic Chunking - чанкинг по семантическим границам (ОЧЕНЬ затратно на embeddings!)
USE_SEMANTIC_CHUNKING=0
# Parent-Child Chunking - двухуровневые чанки
USE_PARENT_CHILD_CHUNKS=1
# HyDE - гипотетические документы (затратно!)
USE_HYDE=0
# Сбор метрик
ENABLE_METRICS=1
# Инкрементальное обновление базы
USE_INCREMENTAL_UPDATES=1

# ============================================
# TELEGRAM (опционально)
# ============================================
# Whitelist пользователей (ID через запятую, пусто = доступ всем)
# Узнать свой ID: напишите @userinfobot
TELEGRAM_WHITELIST=
# Использование файла document_sender.py для отправки документов
ENABLE_DOCUMENT_SENDER=1

# ============================================

# ПРОКСИ (опционально)
# ============================================
# HTTP/HTTPS прокси для Gemini API
# BOT_HTTPS_PROXY=http://user:pass@host:port
# BOT_HTTP_PROXY=http://user:pass@host:port
# Пропустить проверку доступности прокси (1 = да, 0 = нет)
# BOT_FORCE_PROXY=0

# ============================================
# MEMORY CHAT (опционально)
# ============================================
# Включить сохранение истории разговоров
CHAT_HISTORY_ENABLED=1
# Путь к базе данных истории (относительно корня проекта)
# CHAT_HISTORY_DB_PATH=chat_history.db
# Максимальное количество последних сообщений в контексте
MAX_HISTORY_MESSAGES=15
# Порог для автоматической суммаризации (количество сообщений)
SUMMARIZATION_THRESHOLD=30
# Максимальное количество токенов для истории (примерно)
MAX_CONTEXT_TOKENS=8000
# Включить автоматическую суммаризацию длинных разговоров
ENABLE_AUTO_SUMMARIZATION=1
# ============================================
# INTRASERVICE / HELPDESK TICKETS
# ============================================
INTRASERVICE_BASE_URL=https://servicedesk.corporate.loc/
# Basic Auth credentials сервисной учётной записи
INTRASERVICE_LOGIN=IntraTest
INTRASERVICE_PASSWORD=0p{(3/KWuITr0Rx
# Режим аутентификации: basic/negotiate/ntlm
HELPDESK_AUTH_MODE=basic
HELPDESK_REQUIRE_DELEGATION=0
HELPDESK_ALLOW_BASIC_FALLBACK=0
HELPDESK_IDENTITY_SOURCE=login
HELPDESK_SPN=HTTP/servicedesk.corporate.loc
# Создавать тикет от имени пользователя (1) или от сервисной учётки (0)
# При 0 - информация о пользователе добавляется в описание тикета
TICKET_CREATE_ON_BEHALF=0
# SSL verification: false = отключить проверку (для внутренней сети)
INTRASERVICE_SSL_VERIFY=false
# Фиксированные ID для обхода проблемных API endpoints
INTRASERVICE_DEFAULT_SERVICE_ID=106
INTRASERVICE_DEFAULT_TYPE_ID=1020
INTRASERVICE_INITIAL_STATUS_ID=31
INTRASERVICE_MEDIUM_PRIORITY_ID=9

DEFAULT_CITY=Набережные Челны

DATABASE_URL=postgresql://postgres:123456@localhost:5432/itempo
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=15

# === ПАНЕЛЬ АДМИНИСТРАТОРА ===
# Включить веб-панель администратора (1 = да, 0 = нет)
ADMIN_ENABLED=1
# Порт для панели (откройте в браузере: http://localhost:8080)
ADMIN_PORT=8080
# Пароль для входа в панель
ADMIN_PASSWORD=tempo_admin_2024

